USAGE EXAMPLES

# Quick scan for critical issues only
!scan-anti-patterns --severity=critical

# Deep analysis of frontend components
!analyze-anti-patterns --scope=frontend --severity=major

# Implement Phase 1 fixes with auto-validation
@##-anti-pattern-remediation-plan.md --phase=1 --auto-validate

# Check current status and progress
!status-anti-patterns --show-progress --show-metrics

# Validate all implemented fixes
!validate-fixes --check-tests --check-linting

