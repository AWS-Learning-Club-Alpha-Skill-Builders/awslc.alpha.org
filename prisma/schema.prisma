generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model profiles {
  id          String   @id @db.Uuid
  email       String   @db.Text
  full_name   String?  @db.Text
  role        String   @default("member") @db.Text
  is_approved Boolean  @default(false)
  avatar_url  String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

model invites {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique @db.Text
  invited_by String   @db.Uuid
  status     String   @default("pending") @db.Text
  expires_at DateTime @default(dbgenerated("(now() + '7 days'::interval)")) @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model module_progress {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  module_id    String    @db.Uuid
  status       String    @default("todo") @db.Text
  started_at   DateTime? @db.Timestamptz(6)
  completed_at DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([user_id, module_id])
}

model module_submissions {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String    @db.Uuid
  module_id           String    @db.Uuid
  documentation_url   String    @db.Text
  verification_status String    @default("pending") @db.Text
  verification_reason String?   @db.Text
  verified_at         DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
}

model member_enrollments {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  category_id String   @db.Uuid
  enrolled_by String   @db.Uuid
  enrolled_at DateTime @default(now()) @db.Timestamptz(6)

  category skill_categories @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([user_id, category_id])
  @@index([user_id])
}

model skill_modules {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id        String   @db.Uuid
  slug               String   @unique @db.Text
  title              String   @db.Text
  nextwork_url       String   @db.Text
  description        String?  @db.Text
  display_order      Int      @default(0) @db.Integer
  is_active          Boolean  @default(true)
  verification_hints Json     @default("[]")
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)

  category skill_categories @relation(fields: [category_id], references: [id])
}

model skill_categories {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String   @unique @db.Text
  name              String   @db.Text
  emoji             String?  @db.Text
  theme_key         String?  @db.Text
  short_description String?  @db.Text
  long_description  String?  @db.Text
  display_order     Int      @default(0) @db.Integer
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  modules     skill_modules[]
  enrollments member_enrollments[]
}
